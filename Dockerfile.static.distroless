# No RUN step — works when Docker has no outbound network (base image must be cached).
# Build: go build -o iptv-tunerr ./cmd/iptv-tunerr && docker build -f Dockerfile.static.distroless -t iptv-tunerr:hdhr-test .
FROM gcr.io/distroless/static-debian12:nonroot
COPY iptv-tunerr /iptv-tunerr
EXPOSE 5004
ENTRYPOINT ["/iptv-tunerr"]
