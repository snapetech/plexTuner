# Use when binary is pre-built (avoids go mod download in container).
# Build: go build -o iptv-tunerr ./cmd/iptv-tunerr && docker build -f Dockerfile.static -t iptv-tunerr:hdhr-test .
FROM debian:stable-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates ffmpeg wget && rm -rf /var/lib/apt/lists/*
COPY iptv-tunerr /usr/local/bin/iptv-tunerr
EXPOSE 5004
ENTRYPOINT ["iptv-tunerr"]
