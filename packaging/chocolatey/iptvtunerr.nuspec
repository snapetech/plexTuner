<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>iptvtunerr</id>
    <version>0.1.63</version>
    <title>IPTV Tunerr</title>
    <authors>snapetech</authors>
    <projectUrl>https://github.com/snapetech/iptvtunerr</projectUrl>
    <licenseUrl>https://github.com/snapetech/iptvtunerr/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>iptv plex emby jellyfin hdhomerun xmltv live-tv dvr</tags>
    <summary>IPTV to Plex, Emby, and Jellyfin bridge</summary>
