PROJECT=iptvtunerr
GITHUB_REPOSITORY=snapetech/iptvtunerr
BINARY=iptv-tunerr
SERVICE=iptvtunerr
DEFAULT_PORT=34400
HEALTH_PATH=/lineup.json
VERSION_ARGS=--version
RELEASE_ASSET_PREFIX=iptv-tunerr
DEB_ASSET_PATTERN=iptvtunerr_*_amd64.deb
RPM_ASSET_PATTERN=iptvtunerr-*.x86_64.rpm
LINUX_ARCHIVE_ASSET=iptv-tunerr-${version}-linux-amd64.tar.gz
MACOS_ARCHIVE_ASSET=iptv-tunerr-${version}-darwin-amd64.tar.gz
WINDOWS_ARCHIVE_ASSET=iptv-tunerr-${version}-windows-amd64.zip
GHCR_IMAGE=ghcr.io/snapetech/iptvtunerr
DOCKERHUB_IMAGE=snapetech/iptvtunerr
AUR_PACKAGES="iptvtunerr iptvtunerr-bin"
COPR_REPO=slskdn/iptvtunerr
PPA=ppa:keefshape/iptvtunerr
SNAP_NAME=iptvtunerr
CHOCO_PACKAGE=iptvtunerr
WINGET_ID=snapetech.iptvtunerr
HOMEBREW_FORMULA=
NIX_FLAKE=
HELM_CHART=
UNRAID_TEMPLATE=
PROXMOX_SCRIPT=
SYNOLOGY_SPK_DIR=
FLATPAK_MANIFEST=
