# Environment file for the iptvtunerr.service systemd unit.
# Copy provider/media-server settings from .env.minimal.example or .env.example.

IPTV_TUNERR_CATALOG=/var/lib/iptvtunerr/catalog.json
IPTV_TUNERR_CACHE=/var/cache/iptvtunerr
IPTV_TUNERR_BASE_URL=http://127.0.0.1:5004
IPTV_TUNERR_DEVICE_ID=iptvtunerr01
IPTV_TUNERR_FRIENDLY_NAME=IPTV Tunerr
