# Owner/admin token used for Live TV elevation and /livetv/dvrs label discovery.
# Keep this file 0600/root-owned. Do not commit a real token.
IPTV_TUNERR_PMS_TOKEN=owner-token-goes-here
IPTV_TUNERR_PMS_OWNER_TOKEN=owner-token-goes-here

# PMS should normally be reachable only locally from the proxy.
IPTV_TUNERR_PMS_URL=http://127.0.0.1:32400

# Secure default: expose the proxy only to the local HTTPS frontend.
# Use 0.0.0.0:33240 only when another trusted host/pod must connect directly
# and your firewall restricts the source.
IPTV_TUNERR_PLEX_LABEL_PROXY_LISTEN=127.0.0.1:33240
